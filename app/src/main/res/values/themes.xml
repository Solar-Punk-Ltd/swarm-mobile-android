<resources>
    <style name="Theme.SwarmMobile" parent="Theme.MaterialComponents.NoActionBar">
        <!-- Brand -->
        <item name="colorPrimary">@color/swarm_orange</item>
        <item name="colorPrimaryVariant">@color/swarm_orange_dark</item>
        <item name="colorOnPrimary">@color/black</item>
        <item name="colorSecondary">@color/swarm_orange_light</item>
        <item name="colorSecondaryVariant">@color/swarm_orange_dark</item>
        <item name="colorOnSecondary">@color/black</item>

        <!-- Backgrounds -->
        <item name="android:windowBackground">@color/bg_deep</item>
        <item name="colorSurface">@color/bg_surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:colorBackground">@color/bg_deep</item>
        <item name="colorOnBackground">@color/text_primary</item>

        <!-- Status / nav bars -->
        <item name="android:statusBarColor">@color/bg_deep</item>
        <item name="android:navigationBarColor">@color/bg_deep</item>
        <item name="android:windowLightStatusBar" >false</item>

        <!-- Text -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_hint</item>

        <!-- Cards -->
        <item name="materialCardViewStyle">@style/Widget.SwarmMobile.CardView</item>

        <!-- Buttons -->
        <item name="materialButtonStyle">@style/Widget.SwarmMobile.Button</item>
        <item name="borderlessButtonStyle">@style/Widget.SwarmMobile.Button.TextButton</item>

        <!-- Text inputs -->
        <item name="textInputStyle">@style/Widget.SwarmMobile.TextInputLayout</item>
    </style>

    <!-- Card: dark surface with orange stroke -->
    <style name="Widget.SwarmMobile.CardView" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/bg_card</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/stroke</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <!-- Primary filled button: orange bg, black text; grey when disabled -->
    <style name="Widget.SwarmMobile.Button" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/button_filled_bg</item>
        <item name="android:textColor">@color/button_filled_text</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">8dp</item>
    </style>

    <!-- Outlined button: orange stroke + text; grey when disabled -->
    <style name="Widget.SwarmMobile.Button.Outlined" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/button_outlined_stroke</item>
        <item name="android:textColor">@color/button_outlined_stroke</item>
        <item name="cornerRadius">8dp</item>
    </style>

    <!-- Text-only button -->
    <style name="Widget.SwarmMobile.Button.TextButton" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">@color/swarm_orange</item>
    </style>

    <!-- Text input: dark bg, orange focus -->
    <style name="Widget.SwarmMobile.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/bg_elevated</item>
        <item name="boxStrokeColor">@color/stroke</item>
        <item name="hintTextColor">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_hint</item>
    </style>

    <!-- Exposed dropdown variant (node mode spinner) -->
    <style name="Widget.SwarmMobile.TextInputLayout.Exposed" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu">
        <item name="boxBackgroundColor">@color/bg_elevated</item>
        <item name="boxStrokeColor">@color/stroke</item>
        <item name="hintTextColor">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_hint</item>
    </style>
</resources>
