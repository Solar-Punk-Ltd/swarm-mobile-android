<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/bg_surface"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/create_stamp"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider"
            android:layout_marginBottom="16dp" />

        <!-- Depth stepper -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/stamp_depth"
                android:textSize="14sp"
                android:textColor="@color/text_secondary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/depthDecreaseButton"
                style="@style/Widget.SwarmMobile.Button"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="@string/minus"
                android:textSize="18sp"
                android:padding="0dp"
                app:cornerRadius="8dp"
                xmlns:app="http://schemas.android.com/apk/res-auto" />

            <TextView
                android:id="@+id/depthInput"
                android:layout_width="56dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textSize="16sp"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:fontFamily="monospace" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/depthIncreaseButton"
                style="@style/Widget.SwarmMobile.Button"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="@string/plus"
                android:textSize="18sp"
                android:padding="0dp"
                app:cornerRadius="8dp"
                xmlns:app="http://schemas.android.com/apk/res-auto" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/capacityPreviewCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/bg_elevated"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:layout_marginBottom="12dp"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/stamp_capacity_label"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/capacityPreviewText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="@color/swarm_orange"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Duration (TTL) stepper + unit selector -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/stamp_ttl_input_label"
                android:textSize="14sp"
                android:textColor="@color/text_secondary" />

            <!-- Number stepper -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/ttlDecreaseButton"
                style="@style/Widget.SwarmMobile.Button"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="@string/minus"
                android:textSize="18sp"
                android:padding="0dp"
                app:cornerRadius="8dp"
                xmlns:app="http://schemas.android.com/apk/res-auto" />

            <TextView
                android:id="@+id/ttlValueDisplay"
                android:layout_width="48dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textSize="16sp"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:fontFamily="monospace" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/ttlIncreaseButton"
                style="@style/Widget.SwarmMobile.Button"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="@string/plus"
                android:textSize="18sp"
                android:padding="0dp"
                app:cornerRadius="8dp"
                xmlns:app="http://schemas.android.com/apk/res-auto" />

        </LinearLayout>

        <!-- Unit toggle: Days / Weeks / Months -->
        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/ttlUnitToggle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            app:singleSelection="true"
            app:selectionRequired="true"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/unitDays"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/stamp_ttl_unit_days"
                android:textSize="12sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/unitWeeks"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/stamp_ttl_unit_weeks"
                android:textSize="12sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/unitMonths"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/stamp_ttl_unit_months"
                android:textSize="12sp" />

        </com.google.android.material.button.MaterialButtonToggleGroup>

        <!-- Label -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:hint="@string/stamp_label"
            style="@style/Widget.SwarmMobile.TextInputLayout">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/labelInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/immutableCheckbox"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/stamp_immutable"
            android:checked="true"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="20dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider"
            android:layout_marginBottom="12dp" />

        <!-- Indicative price row -->
        <LinearLayout
            android:id="@+id/indicativePriceRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp"
            android:visibility="gone">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/stamp_indicative_price"
                android:textSize="13sp"
                android:textColor="@color/text_secondary" />

            <TextView
                android:id="@+id/indicativePriceText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="@color/swarm_orange"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/cancelButton"
                style="@style/Widget.SwarmMobile.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/cancel"
                android:layout_marginEnd="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/createButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/create" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
